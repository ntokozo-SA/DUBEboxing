{
  "installCommand": "npm install --prefix client",
  "buildCommand": "cd client && DISABLE_ESLINT_PLUGIN=true npm run build",
  "framework": "create-react-app",
  "outputDirectory": "client/build",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*\\.(?:mp4|webm|jpg|jpeg|png|gif|ico|svg|css|js|woff2?|json))",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
